<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VoiceKeyboard.ViewModels"
        x:Class="VoiceKeyboard.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Voice Keyboard"
        Width="360" Height="116"
        WindowStartupLocation="CenterScreen"
        CanResize="False"
        Topmost="True"
        Background="Transparent"
        TransparencyLevelHint="None">

    <Design.DataContext>
        <vm:MainViewModel />
    </Design.DataContext>

    <Border Background="#0d1117" CornerRadius="8" Padding="10,8">
        <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto">

            <!-- Row 0: Audio bar + transcription -->
            <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Spacing="4" Margin="0,0,0,4">
                <Grid Height="4">
                    <Border Background="#161b22" CornerRadius="2" />
                    <Border Background="#3fb950" CornerRadius="2" HorizontalAlignment="Left"
                            Width="340" RenderTransformOrigin="0,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="{Binding AudioLevel}" />
                        </Border.RenderTransform>
                    </Border>
                </Grid>
                <TextBlock Text="{Binding LastTranscription}"
                           Foreground="#c9d1d9" FontSize="11"
                           TextWrapping="NoWrap"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <!-- Row 1: Status + button -->
            <StackPanel Grid.Row="1" Grid.Column="0"
                        Orientation="Horizontal" Spacing="5"
                        VerticalAlignment="Center">
                <Ellipse Width="6" Height="6"
                         Fill="#3fb950" IsVisible="{Binding IsListening}" />
                <Ellipse Width="6" Height="6"
                         Fill="#30363d" IsVisible="{Binding !IsListening}" />
                <TextBlock Text="{Binding StatusText}"
                           Foreground="#8b949e" FontSize="10"
                           VerticalAlignment="Center" />
            </StackPanel>

            <Button Grid.Row="1" Grid.Column="1"
                    Content="{Binding StartButtonText}"
                    Command="{Binding ToggleStartCommand}"
                    IsEnabled="{Binding IsReady}"
                    Padding="10,1" FontSize="10"
                    CornerRadius="3"
                    Foreground="#ffffff"
                    Background="#238636"
                    VerticalAlignment="Center" />

            <!-- Row 2: Shortcuts -->
            <TextBlock Grid.Row="2" Grid.ColumnSpan="2"
                       Text="F9 Start / Stop  ·  Super+F9 Launch"
                       Foreground="#484f58" FontSize="9"
                       HorizontalAlignment="Center"
                       Margin="0,3,0,0" />

        </Grid>
    </Border>

</Window>
